         "times"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"iMin", ",", "iMax"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Min", "[", "Ivals", "]"}], ",", 
          RowBox[{"Max", "[", "Ivals", "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tIMin", "=", 
        RowBox[{"timeSteps", "[", 
         RowBox[{"[", 
          RowBox[{"First", "@", 
           RowBox[{"Ordering", "[", 
            RowBox[{"Ivals", ",", "1"}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tIMax", "=", 
        RowBox[{"timeSteps", "[", 
         RowBox[{"[", 
          RowBox[{"First", "@", 
           RowBox[{"Ordering", "[", 
            RowBox[{"Ivals", ",", 
             RowBox[{"-", "1"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", "Plots", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"plotSIR", "=", 
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{"Evaluate", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"sol", "[", 
