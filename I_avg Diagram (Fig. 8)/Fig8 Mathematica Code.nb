          RowBox[{"PlotRange", "->", "All"}], ",", 
          RowBox[{"PlotStyle", "->", 
           RowBox[{"{", 
            RowBox[{"Blue", ",", "Red", ",", "Green"}], "}"}]}], ",", 
          RowBox[{"PlotLegends", "->", 
