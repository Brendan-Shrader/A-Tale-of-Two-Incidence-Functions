         RowBox[{"[", 
          RowBox[{"First", "@", 
           RowBox[{"Ordering", "[", 
            RowBox[{"Ivals", ",", 
             RowBox[{"-", "1"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", "Plots", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"plotSIR", "=", 
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{"Evaluate", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"sol", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "[", "t", "]"}], ",", 
