 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"runForBeta", "[", 
     RowBox[{"bet_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "siirEquations", ",", "sol", ",", "timeSteps", ",", "Svals", ",", 
        "Ivals", ",", "Rvals", ",", "fftData", ",", "n", ",", "freqs", ",", 
        "validIdx", ",", "peakIdx", ",", "peakFreq", ",", "peakPeriod", ",", 
        "iMin", ",", "iMax", ",", "tIMin", ",", "tIMax", ",", "plotSIR", ",", 
        "plotFFT", ",", "halfIndex"}], "}"}], ",", 
      RowBox[{
       RowBox[{"siirEquations", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"S", "'"}], "[", "t", "]"}], "==", 
           RowBox[{"\[CapitalLambda]", "-", 
            RowBox[{"bet", "*", 
             RowBox[{"S", "[", "t", "]"}], "*", 
             RowBox[{"I1", "[", "t", "]"}]}], "-", 
            RowBox[{"\[Mu]", "*", 
             RowBox[{"S", "[", "t", "]"}]}]}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"I1", "'"}], "[", "t", "]"}], "==", 
           RowBox[{
            RowBox[{"bet", "*", 
             RowBox[{"I1", "[", "t", "]"}], "*", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"S", "[", "t", "]"}], "+", 
               RowBox[{"\[Epsilon]", "*", 
                RowBox[{"R", "[", "t", "]"}]}]}], ")"}]}], "-", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[Gamma]", "+", "\[Mu]", "+", "\[Alpha]I"}], ")"}], "*", 
             RowBox[{"I1", "[", "t", "]"}]}]}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"R", "'"}], "[", "t", "]"}], "==", 
           RowBox[{
            RowBox[{"\[Gamma]", "*", 
             RowBox[{"I1", "[", "t", "]"}]}], "-", 
            RowBox[{"\[Epsilon]", "*", "bet", "*", 
             RowBox[{"R", "[", "t", "]"}], "*", 
             RowBox[{"I1", "[", "t", "]"}]}], "-", 
            RowBox[{"\[Mu]", "*", 
             RowBox[{"R", "[", "t", "]"}]}], "-", 
            RowBox[{"\[Alpha]R", "*", 
             RowBox[{"R", "[", "t", "]"}]}]}]}], ",", 
          RowBox[{
           RowBox[{"S", "[", "0", "]"}], "==", 
           RowBox[{"1", "-", 
            RowBox[{"I1", "[", "0", "]"}]}]}], ",", 
          RowBox[{
           RowBox[{"I1", "[", "0", "]"}], "==", 
           RowBox[{"10", "^", 
            RowBox[{"-", "9"}]}]}], ",", 
          RowBox[{
           RowBox[{"R", "[", "0", "]"}], "==", "0"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sol", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"NDSolveValue", "[", 
          RowBox[{
           RowBox[{"{", "siirEquations", "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"S", ",", "I1", ",", "R"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "tIn", ",", "tFin"}], "}"}], ",", 
           RowBox[{"Method", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<BDF\>\"", ",", 
              RowBox[{"\"\<MaxDifferenceOrder\>\"", "->", "5"}]}], "}"}]}], ",", 
           RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
           RowBox[{"AccuracyGoal", "->", "12"}], ",", 
           RowBox[{"PrecisionGoal", "->", "40"}]}], "]"}]}]}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "Sample", " ", "solutions", " ", "on", " ", "a", " ", "uniform", " ", 
         "grid", " ", "in", " ", "late", " ", "time", " ", "window"}], "*)"}],
        "\[IndentingNewLine]", 
       RowBox[{"timeSteps", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"tStart", ",", "tFin", ",", "dt"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Svals", "=", 
        RowBox[{
         RowBox[{"sol", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "/@", "timeSteps"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Ivals", "=", 
        RowBox[{
         RowBox[{"sol", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "/@", "timeSteps"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Rvals", "=", 
        RowBox[{
         RowBox[{"sol", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "/@", "timeSteps"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fftData", "=", 
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"Fourier", "[", "Svals", "]"}], "]"}], "^", "2"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "Svals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"freqs", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"k", "-", "1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"n", " ", "dt"}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"validIdx", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"2", ",", "n"}], "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"freqs", "[", 
             RowBox[{"[", "#", "]"}], "]"}], "<", "lowFreqThreshold"}], 
           "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"peakIdx", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"validIdx", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}], ",", 
          RowBox[{"validIdx", "[", 
           RowBox[{"[", 
            RowBox[{"First", "@", 
             RowBox[{"Ordering", "[", 
              RowBox[{
               RowBox[{"fftData", "[", 
                RowBox[{"[", "validIdx", "]"}], "]"}], ",", 
               RowBox[{"-", "1"}]}], "]"}]}], "]"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"peakFreq", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MissingQ", "[", "peakIdx", "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<NotAvailable\>\"", "]"}], ",", 
          RowBox[{"freqs", "[", 
           RowBox[{"[", "peakIdx", "]"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"peakPeriod", "=", 
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{"MissingQ", "[", "peakFreq", "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<NoPeak\>\"", "]"}], ",", 
          RowBox[{"peakFreq", ">", "0"}], ",", 
          RowBox[{"1", "/", "peakFreq"}], ",", "True", ",", 
          RowBox[{"Missing", "[", "\"\<NoPeak\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"I", 
